<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
<%- include('partials/header') %>
<%- include('partials/navbar') %>
  <title>Register</title>
  <p><h2>Register</h2>
  Create an account to organize and RSVP to campus events.</p>
  <br>
</head>

<body>
  <form action="/register" method="POST">
    <label for="username">Username</label><br>
    <input type="text" name="username" size='40' placeholder="e.g. jsmith" required>
    <br><br>
    <label for="email">Email</label><br>
    <input type="email" name="email" size='40' placeholder="e.g. jsmith@university.edu.sg" required>
    <br><br>
    <label for="username">Phone</label><br>
    <input type="text" name="phone" size='40' required>
    <br><br>
    <label for="password">Password</label><br>
    <input type="password" name="password" size='40' placeholder="minimum 8 characters" required>
    <br><br>
    Role:
    <select name="role" required>
      <option value="admin">Admin</option>
      <option value="student">Student</option>
    </select>
    <br><br><br>
    <button type="submit">Register</button>
  </form><br>
  <a href="/login">Already have an account? Login</a>

</body>

</html>
