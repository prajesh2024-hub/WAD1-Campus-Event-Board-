<%- include('partials/header') %>
<%- include('partials/navbar') %>

<h2>Delete User Account</h2>

<div class="delete-card">
    <p>Are you sure you want to delete <%= delUsername%>'s account? This cannot be undone.</p>
    <div class="form-actions">
        <form action="/admin-delete-user" method="POST">
            <button type="submit" class="btn-danger">Yes, delete it</button>
            <input type="hidden" name="delUserId" value="<%= delUserId%>">
        </form>
        <a href="/delete-user" class="btn-cancel">No, go back</a>
        
    </div>
</div>

<%- include('partials/footer') %>