<%- include('partials/header') %>
<%- include('partials/navbar') %>

<h2>My Events</h2>

<% if (eventslist.length === 0) { %>
    <p>You have not created any events yet.</p>
<% } else { %>
    <table class="my-events-table">
        <tr>
            <th>Title</th>
            <th>Date</th>
            <th>Time</th>
            <th>Location</th>
            <th>Category</th>
            <th>Max Attendees</th>
            <th>Actions</th>
        </tr>
        <% eventslist.forEach(event => { %>
        <tr>
            <td><%= event.title %></td>
            <td>
              <% if (new Date(event.startDate).toDateString() === new Date(event.endDate).toDateString()) { %>
                <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              <% } else { %>
                <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %> to <%= new Date(event.endDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              <% } %>
            </td>
            <td><%= event.time %></td>
            <td><%= event.venue %></td>
            <td><%= event.category %></td>
            <td><%= event.maxAttendees %></td>
            <td>
                <div class="action-links">
                    <a href="/events/<%= event._id %>/edit">Edit</a>
                    <a href="/events/<%= event._id %>/delete">Delete</a>
                    <a href="/events/<%= event._id %>/reviews">View Reviews</a>
                    <a href="/events/<%= event._id %>/participants">Participants</a>
                </div>
            </td>
        </tr>
        <% }); %>
    </table>
<% } %>

<%- include('partials/footer') %>

