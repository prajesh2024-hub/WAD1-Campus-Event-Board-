<%- include('partials/header') %>
<%- include('partials/navbar') %>

<h2>All Events</h2>

<!-- Search and Filter Bar -->
<form action="/all-events" method="POST" style="margin-bottom: 20px; padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
    <label for="search">Search:</label>
    <input type="text" name="search" id="search" placeholder="Search by title or description" value="<%= search %>">

    <label for="category">Category:</label>
    <select name="category" id="category">
        <option value="">All Categories</option>
        <option value="academic"  <%= category === 'academic'  ? 'selected' : '' %>>Academic</option>
        <option value="social"    <%= category === 'social'    ? 'selected' : '' %>>Social</option>
        <option value="sports"    <%= category === 'sports'    ? 'selected' : '' %>>Sports</option>
        <option value="workshop"  <%= category === 'workshop'  ? 'selected' : '' %>>Workshop</option>
        <option value="other"     <%= category === 'other'     ? 'selected' : '' %>>Other</option>
    </select>

    <label for="dateFrom">From Date:</label>
    <input type="date" name="dateFrom" id="dateFrom" value="<%= dateFrom %>">

    <label for="dateTo">To Date:</label>
    <input type="date" name="dateTo" id="dateTo" value="<%= dateTo %>">

    <button type="submit">Filter</button>
    <a href="/all-events" style="margin-left: 10px;">Clear Filters</a>
</form>

<!-- Show message if no events found -->
<% if (eventslist.length === 0) { %>
    <p>No events found.</p>

<% } else { %>
    <table class="my-events-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Time</th>
                <th>Venue</th>
                <th>Category</th>
                <th>Organizer</th>
                <th>Attendees</th>
                <th>Details</th>
                <th>Wishlist</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>

            <% for (let i = 0; i < eventslist.length; i++) { %>
                <% let event = eventslist[i]; %>
                <% if (event.endDate >= new Date()) { %>
                <tr>
                    <!-- Event title -->
                    <td><strong><%= event.title %></strong></td>

                    <!-- Event start and end date -->
                    <td><%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                    <td><%= new Date(event.endDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                    <td><%= event.time %></td>
                    <td><%= event.venue %></td>
                    <td><%= event.category %></td>
                    <td><%= event.organizer %></td>

                    <td><%= event.attendees.length %> / <%= event.maxAttendees %></td>

                    <td><a href="/events/<%= event.id %>">View Details</a></td>

                    <td>
                        <% let inWishlist = wishlistMap && wishlistMap[event._id.toString()]; %>
                        <% if (inWishlist) { %>
                            <form action="/my-wishlist/events/<%= event.id %>/remove" method="POST" style="display:inline;">
                                <button type="submit" title="Remove from wishlist" class="star-button">★</button>
                            </form>
                        <% } else { %>
                            <form action="/events/<%= event.id %>/wishlist" method="POST" style="display:inline;">
                                <button type="submit" title="Add to wishlist" class="star-button">☆</button>
                            </form>
                        <% } %>
                    </td>

                    <!-- Join event or join waitlist depending on capacity, admin can delete -->
                    <td>
                        <div class="action-links">
                            <% if (event.attendees.length >= event.maxAttendees) { %>
                                <form action="/events/<%= event.id %>/waitlist" method="POST">
                                    <button type="submit">Join Waitlist</button>
                                </form>
                            <% } else { %>
                                <form action="/events/<%= event.id %>/rsvp" method="POST">
                                    <button type="submit">Join Event</button>
                                </form>
                            <% } %>

                            <% if (userRole === 'admin') { %>
                                <form action="/events/<%= event.id %>/delete" method="GET">
                                    <button type="submit">Delete Event</button>
                                </form>
                            <% } %>
                        </div>
                    </td>

                </tr>   
                <% } %>
             <% } %>
        </tbody>
    </table>
<% } %>

<%- include('partials/footer') %>
