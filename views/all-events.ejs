<%- include('partials/header') %>
<%- include('partials/navbar') %>

<h2>All Events</h2>

<!-- Search and Filter Bar -->
<form action="/all-events" method="GET" style="margin-bottom: 20px; padding: 10px; border: 1px solid #ccc; border-radius: 5px;">
    <label for="search">Search:</label>
    <input type="text" name="search" id="search" placeholder="Search by title or description" value="<%= typeof search !== 'undefined' ? search : '' %>">
    
    <label for="category">Category:</label>
    <select name="category" id="category">
        <option value="">All Categories</option>
        <option value="academic" <%= typeof category !== 'undefined' && category === 'academic' ? 'selected' : '' %>>Academic</option>
        <option value="social" <%= typeof category !== 'undefined' && category === 'social' ? 'selected' : '' %>>Social</option>
        <option value="sports" <%= typeof category !== 'undefined' && category === 'sports' ? 'selected' : '' %>>Sports</option>
        <option value="workshop" <%= typeof category !== 'undefined' && category === 'workshop' ? 'selected' : '' %>>Workshop</option>
        <option value="other" <%= typeof category !== 'undefined' && category === 'other' ? 'selected' : '' %>>Other</option>
    </select>
    
    <label for="dateFrom">From Date:</label>
    <input type="date" name="dateFrom" id="dateFrom" value="<%= typeof dateFrom !== 'undefined' ? dateFrom : '' %>">
    
    <label for="dateTo">To Date:</label>
    <input type="date" name="dateTo" id="dateTo" value="<%= typeof dateTo !== 'undefined' ? dateTo : '' %>">
    
    <button type="submit">Filter</button>
    <a href="/all-events" style="margin-left: 10px;">Clear Filters</a>
</form>

<% if (eventslist.length===0) { %>
<p>No events found.</p>
<% } else { %>
    <div style="display:flex;">
        <% eventslist.forEach(event=> { %>
            <% if (event) { %>
            <div style="border:1px solid black; padding:10px; border-radius: 5px; margin-bottom: 10px; width: 200px; margin-right: 10px;">
                <strong><%= event.title %></strong><br><br>
                <% if (new Date(event.startDate).toDateString() === new Date(event.endDate).toDateString()) { %>
                  <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                <% } else { %>
                  <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %> to <%= new Date(event.endDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                <% } %> <br><br>
                <strong>Start Time:</strong> <%= event.time %><br><br>
                <strong>Venue:</strong> <%= event.venue %><br><br>
                <strong>Category:</strong> <%= event.category %><br><br>
                <strong>Organizer:</strong> <%= event.organizer %><br><br>
                <strong>Attendees:</strong> <%= event.attendees.length %> / <%= event.maxAttendees %><br><br>
                <form action="/events/<%= event._id %>/rsvp" method="post">
                    <button type="submit">Join Event</button>
                </form>
            </div>
            <% } %>
        <% }); %>
    </div>
    
<% } %>
    

    <%- include('partials/footer') %>