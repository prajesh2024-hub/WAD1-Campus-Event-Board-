<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container">
  <h1>My Reviews</h1>

  <% if (!myReviews || myReviews.length === 0) { %>
    <p style="color: #666; font-style: italic;">You haven't written any reviews yet. <a href="/all-events">Browse events</a> to get started.</p>
  <% } else { %>
    <p style="color: #6b7280; margin-bottom: 24px;"><%= myReviews.length %> review(s)</p>

    <% myReviews.forEach(({ event, review }) => { %>
      <div class="review-card" id="review-<%= review._id %>">

        <div class="review-header">
          <div>
            <span class="event-title"><%= event.title %></span>
            <span class="review-date">
              <%= new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' }) %>
            </span>
          </div>
        
          <div class="review-actions">
              <a href="/my-reviews?editing=<%= review._id %>" class="btn-edit">Edit</a>
            <form action="/events/<%= event.id %>/reviews/<%= review._id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete this review?')">
              <button type="submit" class="btn-delete">Delete</button>
            </form>
          </div>
        </div>
        <% if (editingId === review._id.toString()) { %>
        <!-- show the edit form -->
          <form id="edit-<%= review._id %>" class="edit-form" action="/events/<%= event.id %>/reviews/<%= review._id %>/update" method="POST" >
          <div class="form-group">
            <label for="rating-<%= review._id %>">Rating</label>
            <select id="rating-<%= review._id %>" name="rating" required>
              <option value="5" <%= review.rating === 5 ? 'selected' : '' %>>⭐⭐⭐⭐⭐ Excellent</option>
              <option value="4" <%= review.rating === 4 ? 'selected' : '' %>>⭐⭐⭐⭐ Very Good</option>
              <option value="3" <%= review.rating === 3 ? 'selected' : '' %>>⭐⭐⭐ Good</option>
              <option value="2" <%= review.rating === 2 ? 'selected' : '' %>>⭐⭐ Fair</option>
              <option value="1" <%= review.rating === 1 ? 'selected' : '' %>>⭐ Poor</option>
            </select>
          </div>
          <div class="form-group">
            <label for="text-<%= review._id %>">Review</label>
            <textarea id="text-<%= review._id %>" name="reviewText" rows="4" required><%= review.reviewText %></textarea>
          </div>
          <div class="edit-form-actions">
            <button type="submit" class="btn-save">Save</button>
            <a href="/my-reviews" class="btn-cancel">Cancel</a>
          </div>
        </form>
        <% } else { %>
        <!-- show the read only view -->
         <div id="view-<%= review._id %>">
          <p class="stars"><% for (let i = 0; i < review.rating; i++) { %>⭐<% } %></p>
          <p class="review-text"><%= review.reviewText %></p>
        </div>
        <% } %>
        
      </div>
    <% }) %>
  <% } %>
</div>

<%- include("partials/footer") %>
