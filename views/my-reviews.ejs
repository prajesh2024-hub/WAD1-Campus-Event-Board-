<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container">
  <h1>My Reviews</h1>

  <% if (!myReviews || myReviews.length === 0) { %>
    <p style="color: #666; font-style: italic;">You haven't written any reviews yet. <a href="/all-events">Browse events</a> to get started.</p>
  <% } else { %>
    <p style="color: #6b7280; margin-bottom: 24px;"><%= myReviews.length %> review(s)</p>

    <% myReviews.forEach(({ event, review }) => { %>
      <div class="review-card" id="review-<%= review._id %>">

        <div class="review-header">
          <div>
            <span class="event-title"><%= event.title %></span>
            <span class="review-date">
              <%= new Date(review.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' }) %>
            </span>
          </div>
          <div class="review-actions">
            <button class="btn-edit" onclick="toggleEdit('<%= review._id %>')">Edit</button>
            <form action="/events/<%= event._id %>/reviews/<%= review._id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete this review?')">
              <button type="submit" class="btn-delete">Delete</button>
            </form>
          </div>
        </div>

        <!-- Read-only view -->
        <div id="view-<%= review._id %>">
          <p class="stars"><% for (let i = 0; i < review.rating; i++) { %>⭐<% } %></p>
          <p class="review-text"><%= review.reviewText %></p>
        </div>

        <!-- Edit form (hidden by default) -->
        <form id="edit-<%= review._id %>" class="edit-form" action="/events/<%= event._id %>/reviews/<%= review._id %>/update" method="POST" style="display:none;">
          <div class="form-group">
            <label for="rating-<%= review._id %>">Rating</label>
            <select id="rating-<%= review._id %>" name="rating" required>
              <option value="5" <%= review.rating === 5 ? 'selected' : '' %>>⭐⭐⭐⭐⭐ Excellent</option>
              <option value="4" <%= review.rating === 4 ? 'selected' : '' %>>⭐⭐⭐⭐ Very Good</option>
              <option value="3" <%= review.rating === 3 ? 'selected' : '' %>>⭐⭐⭐ Good</option>
              <option value="2" <%= review.rating === 2 ? 'selected' : '' %>>⭐⭐ Fair</option>
              <option value="1" <%= review.rating === 1 ? 'selected' : '' %>>⭐ Poor</option>
            </select>
          </div>
          <div class="form-group">
            <label for="text-<%= review._id %>">Review</label>
            <textarea id="text-<%= review._id %>" name="reviewText" rows="4" required><%= review.reviewText %></textarea>
          </div>
          <div class="edit-form-actions">
            <button type="submit" class="btn-save">Save</button>
            <button type="button" class="btn-cancel" onclick="toggleEdit('<%= review._id %>')">Cancel</button>
          </div>
        </form>

      </div>
    <% }) %>
  <% } %>
</div>

<script>
  function toggleEdit(reviewId) {
    const view = document.getElementById('view-' + reviewId);
    const form = document.getElementById('edit-' + reviewId);
    const isEditing = form.style.display !== 'none';
    view.style.display = isEditing ? 'block' : 'none';
    form.style.display = isEditing ? 'none' : 'block';
  }
</script>

<style>
  .review-card {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 18px 20px;
    margin-bottom: 16px;
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 10px;
    gap: 12px;
  }

  .event-title {
    font-weight: bold;
    color: #1d4ed8;
    display: block;
    margin-bottom: 4px;
  }

  .review-date {
    font-size: 13px;
    color: #9ca3af;
  }

  .review-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .stars {
    margin: 0 0 6px 0;
    font-size: 16px;
  }

  .review-text {
    margin: 0;
    color: #374151;
    line-height: 1.6;
  }

  .btn-edit {
    background: #1d4ed8;
    color: white;
    border: none;
    border-radius: 4px;
    padding: 6px 14px;
    cursor: pointer;
    font-size: 13px;
  }

  .btn-edit:hover { background: #1e40af; }

  .btn-delete {
    background: #dc2626;
    color: white;
    border: none;
    border-radius: 4px;
    padding: 6px 14px;
    cursor: pointer;
    font-size: 13px;
  }

  .btn-delete:hover { background: #b91c1c; }

  .edit-form {
    margin-top: 10px;
  }

  .edit-form .form-group {
    margin-bottom: 12px;
  }

  .edit-form label {
    display: block;
    font-weight: bold;
    margin-bottom: 4px;
    color: #374151;
    font-size: 14px;
  }

  .edit-form select,
  .edit-form textarea {
    width: 100%;
    padding: 8px;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    font-size: 14px;
    box-sizing: border-box;
  }

  .edit-form textarea { resize: vertical; }

  .edit-form-actions {
    display: flex;
    gap: 8px;
  }

  .btn-save {
    background: #16a34a;
    color: white;
    border: none;
    border-radius: 4px;
    padding: 8px 18px;
    cursor: pointer;
    font-size: 14px;
  }

  .btn-save:hover { background: #15803d; }

  .btn-cancel {
    background: #9ca3af;
    color: white;
    border: none;
    border-radius: 4px;
    padding: 8px 18px;
    cursor: pointer;
    font-size: 14px;
  }

  .btn-cancel:hover { background: #6b7280; }
</style>

<%- include("partials/footer") %>
