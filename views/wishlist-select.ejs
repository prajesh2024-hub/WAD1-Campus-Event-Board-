<%- include('partials/header') %>
<%- include('partials/navbar') %>

<h2>Add to Wishlist</h2>

<p>Choose where to add "<strong><%= event.title %></strong>".</p>

<form action="/events/<%= event._id %>/wishlist" method="POST" class="create-event-form">
  <% if (collections.length > 0) { %>
    <h3>Select existing collection</h3>
    <% collections.forEach(collection => { %>
      <div style="margin-bottom: 8px;">
        <label>
          <input type="radio" name="collectionId" value="<%= collection._id %>" />
          <%= collection.name %>
        </label>
      </div>
    <% }); %>
  <% } else { %>
    <p>You don't have any wishlist collections yet.</p>
  <% } %>

  <h3>Create new collection</h3>
  <input type="text" name="newCollectionName" placeholder="New collection name" style="width: 100%; padding: 8px; margin-bottom: 10px;" />

  <div class="form-actions">
    <button type="submit" class="btn-primary">Add to wishlist</button>
    <a href="/all-events" class="btn-cancel">Cancel</a>
  </div>
</form>

<%- include('partials/footer') %>