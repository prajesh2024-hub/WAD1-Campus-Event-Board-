<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('partials/header') %>
        <%- include('partials/navbar') %>
            <div class="container">
                <br>
                <title>Reset Password</title>
               
                <h2>Reset Password</h2>
                <p style="color:#686868;">If your details match our records, you will be redirected to update your password.</p>
                <br>
            </div>
</head>

<body>
    <div class="container">
        <form action="/reset-password" method="POST">

            <label for="email">Email</label><br>
            <input type="text" name="email" size='40' placeholder="e.g. you@university.edu.sg" required>
            <br><br>
            <label for="phone">Phone</label><br>
            <input type="text" name="phone" size='40' required>
            <br><br><br>
            <button type="submit">Enter</button>
        </form>
        <br>
    </div>
    <%- include('partials/footer') %>

</html>