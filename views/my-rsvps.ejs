<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container">
  <h1>My RSVPs</h1>
  <% 
  // get the current date and time to compare events against "now"
  const now = new Date();

  // filter all events and keep only the ones where the current user is attending
  const attendingEvents = events.filter(event => 
    event.attendees && event.attendees.some(attendee => attendee._id.toString() === currentUser.id.toString()));
  // events where the start date is >= today
  const upcomingEvents = attendingEvents.filter(event => new Date(event.startDate) >= now);
  //events where the end date already passed
  const pastEvents = attendingEvents.filter(event => new Date(event.endDate) < now);
  const waitlistEvents = events.filter(event => 
    event.waitlist && event.waitlist.some(id => id.toString() === currentUser.id.toString())
  ); %>

  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('bookings')">Bookings (<%= upcomingEvents.length %>)</button>
    <button class="tab-btn" onclick="switchTab('waitlist')">Waitlist (<%= waitlistEvents.length %>)</button>
    <button class="tab-btn" onclick="switchTab('past')">Past Bookings (<%= pastEvents.length %>)</button>
  </div>

  <!-- Bookings Tab -->
  <div id="bookings" class="tab-content active">
    <% if (upcomingEvents.length === 0) { %>
      <p>You have no upcoming bookings.</p>
    <% } else { %>
      <% upcomingEvents.forEach(event => { %>
        <div class="event-card">
          <h3><%= event.title %></h3>
          <p><%= event.description %></p>

          <!-- display either a single date or a date range -->
          <p><strong>Date:</strong> 
            <% if (new Date(event.startDate).toDateString() === new Date(event.endDate).toDateString()) { %>
              <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            <% } else { %>
              <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %> to <%= new Date(event.endDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            <% } %>
          </p>
          <p><strong>Time:</strong> <%= event.time %></p>
          <p><strong>Venue:</strong> <%= event.venue %></p>
          <p><strong>Organizer:</strong> <%= event.createdBy ? event.createdBy.name : 'Unknown' %></p>
          <p><strong>Attendance:</strong> <%= event.attendees.length %> / <%= event.maxAttendees %></p>

          <p><a href="/events/<%= event._id %>">View Details</a></p>

          <form action="/events/<%= event._id %>/cancel-rsvp" method="POST">
            <button type="submit">Cancel RSVP</button>
          </form>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Waitlist Tab -->
  <div id="waitlist" class="tab-content">
    <% if (waitlistEvents.length === 0) { %>
      <p>You are not on any waitlists.</p>
    <% } else { %>
      <% waitlistEvents.forEach(event => { %>
        <div class="event-card waitlist-card">
          <h3><%= event.title %></h3>
          <p><%= event.description %></p>
          <p><strong>Date:</strong> 
            <% if (new Date(event.startDate).toDateString() === new Date(event.endDate).toDateString()) { %>
              <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            <% } else { %>
              <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %> to <%= new Date(event.endDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            <% } %>
          </p>
          <p><strong>Time:</strong> <%= event.time %></p>
          <p><strong>Venue:</strong> <%= event.venue %></p>
          <p><strong>Status:</strong> 
            <% 
              let waitlistPosition = 0;
              if (event.waitlist && Array.isArray(event.waitlist)) {
                waitlistPosition = event.waitlist.findIndex(id => 
                  id && id.toString() === currentUser.id.toString()
                ) + 1;
              }
            %>
            <span class="waitlist-badge">On Waitlist (Position: <%= waitlistPosition %>)</span>
          </p>
          <p><strong>Organizer:</strong> <%= event.createdBy ? event.createdBy.name : 'Unknown' %></p>

          <p><a href="/events/<%= event._id %>">View Details</a></p>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Past Bookings Tab -->
  <div id="past" class="tab-content">
    <% if (pastEvents.length === 0) { %>
      <p>You have no past bookings.</p>
    <% } else { %>
      <% pastEvents.forEach(event => { %>
        <div class="event-card past-card">
          <h3><%= event.title %></h3>
          <p><%= event.description %></p>
          <p><strong>Date:</strong> 
            <% if (new Date(event.startDate).toDateString() === new Date(event.endDate).toDateString()) { %>
              <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            <% } else { %>
              <%= new Date(event.startDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %> to <%= new Date(event.endDate).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            <% } %>
          </p>
          <p><strong>Time:</strong> <%= event.time %></p>
          <p><strong>Venue:</strong> <%= event.venue %></p>
          <p><strong>Organizer:</strong> <%= event.createdBy ? event.createdBy.name : 'Unknown' %></p>

          <a href="/events/<%= event._id %>/review"><button>Leave a review</button></a>

          <p><a href="/events/<%= event._id %>">View Details</a></p>
        </div>
      <% }) %>
    <% } %>
  </div>

</div>

<style>
  .tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    border-bottom: 2px solid #ddd;
  }

  .tab-btn {
    padding: 10px 20px;
    background: #f0f0f0;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .tab-btn:hover {
    background: #e0e0e0;
  }

  .tab-btn.active {
    background: #1d4ed8;
    color: white;
    border-bottom-color: #1d4ed8;
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  .waitlist-badge {
    background: #fbbf24;
    color: #78350f;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .waitlist-card {
    opacity: 0.8;
    border-left: 4px solid #fbbf24;
  }

  .past-card {
    border-left: 4px solid #9ca3af;
  }
</style>

<script>
  function switchTab(tabName) {
    // Hide all tab content
    const contents = document.querySelectorAll('.tab-content');
    contents.forEach(content => content.classList.remove('active'));

    // Remove active class from all buttons
    const buttons = document.querySelectorAll('.tab-btn');
    buttons.forEach(btn => btn.classList.remove('active'));

    // Show selected tab content and mark button as active
    document.getElementById(tabName).classList.add('active');
    event.target.classList.add('active');
  }
</script>

<%- include("partials/footer") %>