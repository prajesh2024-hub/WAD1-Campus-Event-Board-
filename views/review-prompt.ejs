<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container">
  <h1>Leave a Review for <%= event.title %></h1>

  <div class="review-form-container">
    <% if (alreadyReviewed) { %>
      <p>You have already submitted a review for this event.</p>
      <div class="form-actions">
        <a href="/events/<%= event._id %>" class="btn-secondary">Back to Event</a>
        <a href="/my-reviews" class="btn-secondary">View My Reviews</a>
      </div>
    <% } else { %>
    <form method="POST" action="/events/<%= event._id %>/review">
      <div class="form-group">
        <label for="rating"><strong>Rating:</strong></label>
        <select id="rating" name="rating" required>
          <option value="">Select a rating</option>
          <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
          <option value="4">⭐⭐⭐⭐ Very Good</option>
          <option value="3">⭐⭐⭐ Good</option>
          <option value="2">⭐⭐ Fair</option>
          <option value="1">⭐ Poor</option>
        </select>
      </div>

      <div class="form-group">
        <label for="reviewText"><strong>Your Review:</strong></label>
        <textarea
          id="reviewText"
          name="reviewText"
          rows="6"
          placeholder="Share your experience at this event..."
          required></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Submit Review</button>
        <a href="/events/<%= event._id %>" class="btn-secondary">Cancel</a>
      </div>
    </form>
    <% } %>
  </div>
</div>

<style>
  .review-form-container {
    max-width: 600px;
    margin: 20px auto;
    padding: 20px;
    background: #f9f9f9;
    border-radius: 8px;
    border: 1px solid #ddd;
  }

  .form-group {
    margin-bottom: 20px;
  }

  .form-group label {
    display: block;
    margin-bottom: 8px;
    color: #333;
  }

  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-family: Arial, sans-serif;
    font-size: 14px;
    box-sizing: border-box;
  }

  .form-group textarea {
    resize: vertical;
  }

  .form-actions {
    display: flex;
    gap: 10px;
  }

  .btn-primary,
  .btn-secondary {
    padding: 10px 20px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .btn-primary {
    background: #1d4ed8;
    color: white;
  }

  .btn-primary:hover {
    background: #1e40af;
  }

  .btn-secondary {
    background: #ccc;
    color: #333;
  }

  .btn-secondary:hover {
    background: #bbb;
  }
</style>

<%- include("partials/footer") %>