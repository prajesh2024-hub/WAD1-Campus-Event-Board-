<%- include("partials/header") %>
<%- include("partials/navbar") %>

<div class="container">
  <h1>Leave a Review for <%= event.title %></h1>

  <div class="review-form-container">
    <% if (alreadyReviewed) { %>
      <p>You have already submitted a review for this event.</p>
      <div class="form-actions">
        <a href="/events/<%= event.id %>" class="btn-secondary">Back to Event</a>
        <a href="/my-reviews" class="btn-secondary">View My Reviews</a>
      </div>
    <% } else { %>
    <form method="POST" action="/events/<%= event.id %>/review">
      <div class="form-group">
        <label for="rating"><strong>Rating:</strong></label>
        <select id="rating" name="rating" required>
          <option value="">Select a rating</option>
          <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
          <option value="4">⭐⭐⭐⭐ Very Good</option>
          <option value="3">⭐⭐⭐ Good</option>
          <option value="2">⭐⭐ Fair</option>
          <option value="1">⭐ Poor</option>
        </select>
      </div>

      <div class="form-group">
        <label for="reviewText"><strong>Your Review:</strong></label>
        <textarea
          id="reviewText"
          name="reviewText"
          rows="6"
          placeholder="Share your experience at this event..."
          required></textarea>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Submit Review</button>
        <a href="/events/<%= event.id %>" class="btn-secondary">Cancel</a>
      </div>
    </form>
    <% } %>
  </div>
</div>

<%- include("partials/footer") %>